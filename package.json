		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/eslint": "^9.6.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"gh-pages": "^6.3.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.9",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"vite": "^7.3.1 ",
		"vitest": "^4.0.18"
	},
	"type": "module",
	"dependencies": {
		"@threlte/core": "^8.4.1",
